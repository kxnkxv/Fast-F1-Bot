# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# WebApp URL (where the React app is served)
WEBAPP_URL=https://your-domain.com

# Redis (optional, falls back to memory-only cache)
REDIS_URL=redis://localhost:6379/0

# FastF1 cache directory
FF1_CACHE_DIR=./ff1_cache

# Season override (defaults to current year)
# CURRENT_SEASON=2025

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
